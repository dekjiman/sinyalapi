generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String               @id @default(uuid())
  email             String               @unique
  passwordHash      String?              @map("password_hash")
  name              String?
  authProvider      String               @default("email") @map("auth_provider")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  auditLogs         AuditLog[]
  createdKeywords   MonitoredKeyword[]
  overrides         PostClassification[]
  connectedAccounts SocialAccount[]
  workspaceMembers  WorkspaceMember[]
  workspaces        Workspace[]

  @@map("users")
}

model Workspace {
  id          String                @id @default(uuid())
  name        String
  ownerUserId String                @map("owner_user_id")
  plan        String                @default("free")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  auditLogs   AuditLog[]
  competitors MonitoredCompetitor[]
  keywords    MonitoredKeyword[]
  accounts    SocialAccount[]
  posts       SocialPost[]
  syncJobs    SyncJob[]
  members     WorkspaceMember[]
  owner       User                  @relation(fields: [ownerUserId], references: [id])

  @@index([ownerUserId], map: "workspaces_owner_user_id_fkey")
  @@map("workspaces")
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  userId      String    @map("user_id")
  role        String
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId], map: "workspace_members_user_id_fkey")
  @@map("workspace_members")
}

model SocialAccount {
  id                   String       @id @default(uuid())
  workspaceId          String       @map("workspace_id")
  connectedByUserId    String?      @map("connected_by_user_id")
  platform             String       @default("threads")
  platformUserId       String       @map("platform_user_id")
  username             String?
  displayName          String?      @map("display_name")
  biography            String?      @db.Text
  profilePictureUrl    String?      @map("profile_picture_url") @db.Text
  isVerified           Boolean      @default(false) @map("is_verified")
  followersCount       Int?         @map("followers_count")
  likesCount           Int?         @map("likes_count")
  quotesCount          Int?         @map("quotes_count")
  repostsCount         Int?         @map("reposts_count")
  viewsCount           Int?         @map("views_count")
  accessToken          String?      @map("access_token") @db.Text
  tokenExpiresAt       DateTime?    @map("token_expires_at")
  connectionStatus     String       @default("active") @map("connection_status")
  lastSyncedAt         DateTime?    @map("last_synced_at")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  connectedBy          User?        @relation(fields: [connectedByUserId], references: [id])
  workspace            Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  posts                SocialPost[]

  @@unique([workspaceId, platform, platformUserId])
  @@index([connectedByUserId], map: "social_accounts_connected_by_user_id_fkey")
  @@map("social_accounts")
}

model SocialPost {
  id                        String               @id @default(uuid())
  workspaceId               String               @map("workspace_id")
  platform                  String               @default("threads")
  socialAccountId           String?              @map("social_account_id")
  externalPostId            String               @map("external_post_id")
  authorUsername            String?              @map("author_username")
  postText                  String?              @map("post_text") @db.Text
  permalink                 String?              @db.Text
  mediaType                 String?              @map("media_type")
  mediaProductType          String?              @map("media_product_type")
  shortcode                 String?
  thumbnailUrl              String?              @map("thumbnail_url") @db.Text
  children                  Json?
  isQuotePost               Boolean?             @map("is_quote_post")
  quotedPost                Json?                @map("quoted_post")
  repostedPost              Json?                @map("reposted_post")
  altText                   String?              @map("alt_text") @db.Text
  linkAttachmentUrl         String?              @map("link_attachment_url") @db.Text
  gifUrl                    String?              @map("gif_url") @db.Text
  pollAttachment            Json?                @map("poll_attachment")
  topicTag                  String?              @map("topic_tag")
  isSpoilerMedia            Boolean?             @map("is_spoiler_media")
  textEntities              Json?                @map("text_entities")
  textAttachment            String?              @map("text_attachment") @db.Text
  ghostPostStatus           String?              @map("ghost_post_status")
  ghostPostExpirationTs     DateTime?            @map("ghost_post_expiration_timestamp")
  isVerified                Boolean?             @map("is_verified")
  authorProfilePictureUrl   String?              @map("profile_picture_url") @db.Text
  ownerId                   String?              @map("owner_id")
  publishedAt               DateTime?            @map("published_at")
  source                    String
  rawPayload                Json?                @map("raw_payload")
  createdAt                 DateTime             @default(now()) @map("created_at")
  updatedAt                 DateTime             @updatedAt @map("updated_at")
  classifications           PostClassification[]
  metrics                   PostMetric[]
  account                   SocialAccount?       @relation(fields: [socialAccountId], references: [id])
  workspace                 Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([platform, externalPostId])
  @@index([socialAccountId], map: "social_posts_social_account_id_fkey")
  @@index([workspaceId], map: "social_posts_workspace_id_fkey")
  @@map("social_posts")
}

model PostMetric {
  id                String     @id @default(uuid())
  postId            String     @map("post_id")
  views             Int?
  likes             Int?
  replies           Int?
  reposts           Int?
  quotes            Int?
  shares            Int?
  engagementTotal   Int?       @map("engagement_total")
  engagementRate    Decimal?   @map("engagement_rate") @db.Decimal(10, 4)
  metricCollectedAt DateTime   @default(now()) @map("metric_collected_at")
  post              SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId], map: "post_metrics_post_id_fkey")
  @@map("post_metrics")
}

model MonitoredKeyword {
  id               String    @id @default(uuid())
  workspaceId      String    @map("workspace_id")
  queryString      String    @map("query_string") @db.Text
  includeTerms     Json?     @map("include_terms")
  excludeTerms     Json?     @map("exclude_terms")
  language         String?
  country          String?
  sourcePreference String    @default("official_first") @map("source_preference")
  syncFrequency    String    @default("manual") @map("sync_frequency")
  lastSyncedAt     DateTime? @map("last_synced_at")
  isActive         Boolean   @default(true) @map("is_active")
  createdByUserId  String    @map("created_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  createdBy        User      @relation(fields: [createdByUserId], references: [id])
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([createdByUserId], map: "monitored_keywords_created_by_user_id_fkey")
  @@index([workspaceId], map: "monitored_keywords_workspace_id_fkey")
  @@map("monitored_keywords")
}

model MonitoredCompetitor {
  id               String    @id @default(uuid())
  workspaceId      String    @map("workspace_id")
  username         String
  displayName      String?   @map("display_name")
  sourcePreference String    @default("official_first") @map("source_preference")
  lastSyncedAt     DateTime? @map("last_synced_at")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId], map: "monitored_competitors_workspace_id_fkey")
  @@map("monitored_competitors")
}

model PostClassification {
  id                    String     @id @default(uuid())
  postId                String     @map("post_id")
  sentiment             String?
  topic                 String?
  confidenceScore       Decimal?   @map("confidence_score") @db.Decimal(5, 4)
  classificationVersion String?    @map("classification_version")
  isManualOverride      Boolean    @default(false) @map("is_manual_override")
  overriddenByUserId    String?    @map("overridden_by_user_id")
  createdAt             DateTime   @default(now()) @map("created_at")
  overriddenBy          User?      @relation(fields: [overriddenByUserId], references: [id])
  post                  SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([overriddenByUserId], map: "post_classifications_overridden_by_user_id_fkey")
  @@index([postId], map: "post_classifications_post_id_fkey")
  @@map("post_classifications")
}

model SyncJob {
  id               String    @id @default(uuid())
  workspaceId      String    @map("workspace_id")
  jobType          String    @map("job_type")
  jobStatus        String    @map("job_status")
  source           String?
  queryReferenceId String?   @map("query_reference_id")
  startedAt        DateTime? @map("started_at")
  completedAt      DateTime? @map("completed_at")
  errorMessage     String?   @map("error_message") @db.Text
  retryCount       Int       @default(0) @map("retry_count")
  createdAt        DateTime  @default(now()) @map("created_at")
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId], map: "sync_jobs_workspace_id_fkey")
  @@map("sync_jobs")
}

model AuditLog {
  id          String     @id @default(uuid())
  workspaceId String?    @map("workspace_id")
  userId      String?    @map("user_id")
  action      String
  entityType  String?    @map("entity_type")
  entityId    String?    @map("entity_id")
  metadata    Json?     @map("metadata")
  createdAt   DateTime   @default(now()) @map("created_at")
  user        User?      @relation(fields: [userId], references: [id])
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([userId], map: "audit_logs_user_id_fkey")
  @@index([workspaceId], map: "audit_logs_workspace_id_fkey")
  @@map("audit_logs")
}
